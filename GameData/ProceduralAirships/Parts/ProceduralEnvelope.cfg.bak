PART
{
    name = proceduralEnvelope
    module = Part
    author = tsingshitao
    	// --- asset parameters ---
	MODEL
	{
		model = ProceduralParts/Parts/cylinderTank
		scale = 1,1,1
	}
	scale = 1
	rescaleFactor = 1


    // ----- 编辑器分类 -----
    category = Aero
    subcategory = 0
    	// --- node definitions ---
	node_stack_top=0,0.5,0,0,1,0,1
	node_stack_bottom=0,-0.5,0,0,-1,0,1
	node_attach=0,0,0.5,0,0,-1,1


    title = Procedural Airship Envelope
    manufacturer = Greenstone Industries & Hooligan Labs
    description = A fully scalable airship envelope. Lift scales automatically with volume. Uses Hooligan Labs buoyancy model.

    // ----- 科技与成本 -----
    TechRequired = start
    entryCost = 12000
    cost = 800
    mass = 0.5
    crashTolerance = 12
    breakingForce = 200
    breakingTorque = 200
    maxTemp = 2900
    tags = airship blimp procedural envelope buoyancy lift

	attachRules = 1,1,1,1,0

    // ----- 程序化部件主模块 -----
    MODULE
    {
        name = ProceduralPart
        textureSet = PlainWhite
        costPerkL = 200

        diameterMin = 0.5
        diameterMax = 5.0
        lengthMin = 1.0
        lengthMax = 10.0
        volumeMin = 0.3
        volumeMax = 100.0

        UPGRADES
        {
            UPGRADE
            {
                name__ = ProceduralPartsTankUnlimited
                diameterMin = 0.01
                diameterMax = Infinity
                lengthMin = 0.01
                lengthMax = Infinity
                volumeMin = 0
                volumeMax = Infinity
            }
        }
    }

    // ----- 程序化形状（每个必须有 displayName） -----
    MODULE
    {
        name = ProceduralShapeCylinder
        displayName = Cylinder
        length = 5.0
        diameter = 3.75
    }
    MODULE
    {
        name = ProceduralShapeCone
        displayName = Cone
        length = 5.0
        topDiameter = 2.5
        bottomdiameter = 3.75
    }
    MODULE
    {
        name = ProceduralShapePill
        displayName = Pill
        length = 5.0
        diameter = 3.75
        fillet = 0.5
    }
    MODULE
    {
        name = ProceduralShapeBezierCone
        displayName = Bezier Cone
        length = 5.0
        topDiameter = 2.5
        bottomdiameter = 3.75
    }
    MODULE
    {
        name = ProceduralShapePolygon
        displayName = Polygon
        length = 5.0
        diameter = 3.75
    }

    // ----- HL 气囊模块（初始值会被动态覆盖） -----
    MODULE
    {
        name = HLEnvelopePartModule
        envelopeVolume = 20.0
        envelopeVolumeScale = 1.0
        specificVolumeFractionEnvelope = 0.0
        compressRate = 0.05
        expandRate = 0.05
        minAtmPressure = -0.01
        makeStationarySpeedMax = 10
        makeStationarySpeedClamp = 0.05
        envelopeHasAnimation = false
    }

    // ----- 同步模块：将程序化体积映射到浮力 -----
    MODULE
    {
        name = ProceduralEnvelopeVolumeModule
        volumeScale = 20 
    }
}